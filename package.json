{
  "name": "@rizz-zone/opencode-ralph",
  "version": "0.1.0",
  "description": "Keep OpenCode working in the same session by continuing when it goes idle.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rizz-zone/opencode-ralph.git"
  },
  "bugs": {
    "url": "https://github.com/rizz-zone/opencode-ralph/issues"
  },
  "homepage": "https://github.com/rizz-zone/opencode-ralph#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts --outdir dist --target bun --format esm --packages external",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish",
    "install:global": "bun run build && bun scripts/install-global.ts",
    "uninstall:global": "bun scripts/uninstall-global.ts",
    "prepack": "bun run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "agent",
    "loop"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "bun@1.3.11",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@opencode-ai/plugin": "1.4.3"
  }
}
